#!/bin/bash
{{ if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}
set -e

# Make sure brew is on PATH (macOS, non-interactive shell) so `which fish`
# finds a Homebrew-installed fish.
if ! command -v fish &>/dev/null; then
    if [ -x /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -x /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
fi

# Set fish as the default shell
FISH_PATH=$(command -v fish)

if [ -z "$FISH_PATH" ]; then
    echo "Fish shell not found. Please install it first."
    exit 1
fi

echo "Setting fish as default shell..."

# Add fish to /etc/shells if not already there (required before chsh accepts it)
if ! grep -q "^$FISH_PATH\$" /etc/shells; then
    echo "Adding $FISH_PATH to /etc/shells..."
    echo "$FISH_PATH" | sudo tee -a /etc/shells
fi

# Change default shell to fish
if [ "$SHELL" != "$FISH_PATH" ]; then
    echo "Changing default shell to fish..."
    sudo chsh -s "$FISH_PATH" "$USER"
    echo "Default shell changed to fish. Log out and back in (or open a new terminal) for it to take effect."
else
    echo "Fish is already your default shell."
fi

{{ else -}}
echo "Skipping: unsupported OS"
{{ end -}}
