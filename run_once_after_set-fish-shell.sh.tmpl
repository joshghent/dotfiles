#!/bin/bash
{{ if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}

# Make fish the interactive shell. The clean way is chsh (changes the login
# shell), but that edits the user database and needs root / admin — which you
# don't have as a non-admin user (e.g. a separate-admin macOS account). So when
# chsh isn't possible we fall back to exec'ing fish from the login shell's rc,
# which needs no privilege at all. Either way you land in fish.

# Locate fish: system, Homebrew, or mise.
if ! command -v fish &>/dev/null; then
    if [ -x /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -x /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
fi
[ -x "$HOME/.local/bin/mise" ] && export PATH="$HOME/.local/bin:$PATH"

FISH_PATH=$(command -v fish || true)
if [ -z "$FISH_PATH" ]; then
    echo "fish not installed — leaving your shell unchanged."
    exit 0
fi
if [ "$SHELL" = "$FISH_PATH" ]; then
    echo "fish is already your login shell."
    exit 0
fi

# Detect privilege for the chsh path.
SUDO=""
if [ "$(id -u)" -eq 0 ]; then
    SUDO=""
elif sudo -n true 2>/dev/null; then
    SUDO="sudo"
elif [ -t 0 ] && sudo -v 2>/dev/null; then
    SUDO="sudo"
fi

changed_login_shell=0
if [ "$(id -u)" -eq 0 ] || [ -n "$SUDO" ]; then
    # fish must be listed in /etc/shells before chsh will accept it.
    if ! grep -qx "$FISH_PATH" /etc/shells 2>/dev/null; then
        echo "$FISH_PATH" | $SUDO tee -a /etc/shells >/dev/null
    fi
    if $SUDO chsh -s "$FISH_PATH" "$USER" 2>/dev/null; then
        echo "Login shell changed to fish."
        changed_login_shell=1
    fi
fi

if [ "$changed_login_shell" -eq 0 ]; then
    # No privilege (or chsh failed): launch fish from the login shell's rc.
    echo "Couldn't change the login shell — adding an 'exec fish' launcher to your shell rc instead."
    guard='# launch fish for interactive sessions (set by chezmoi)
if [ -z "$FISH_LAUNCHED" ] && command -v fish >/dev/null 2>&1; then
    export FISH_LAUNCHED=1
    case $- in *i*) exec fish ;; esac
fi'
    for rc in "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.zshrc" "$HOME/.profile"; do
        [ -e "$rc" ] || continue
        if ! grep -q 'set by chezmoi' "$rc" 2>/dev/null; then
            printf '\n%s\n' "$guard" >> "$rc"
            echo "  added fish launcher to $rc"
        fi
    done
fi

echo "Open a new terminal (or re-login) for fish to take effect."

{{ else -}}
echo "Skipping: unsupported OS"
{{ end -}}
