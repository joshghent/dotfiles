.config/nvim/lazy-lock.json

# Ignore macOS-specific files on non-Darwin systems
{{ if ne .chezmoi.os "darwin" }}
.config/aerospace/
.config/borders/
.config/sketchybar/
run_once_before_install-packages-darwin.sh.tmpl
{{ end }}

# Ignore Linux-specific files on non-Linux systems
{{ if ne .chezmoi.os "linux" }}
run_once_before_install-packages-linux.sh.tmpl
.config/autostart/ulauncher.desktop
{{ end }}

# ~/mise.toml holds machine-local tool pins (e.g. work terraform/dotnet versions)
# and must never be managed — global defaults live in .config/mise/config.toml
mise.toml

# authorized_keys is host-specific (each server grants its own access keys).
# Never manage it from the repo — overwriting it can lock you out of a box.
.ssh/authorized_keys
