#!/bin/bash
{{ if eq .chezmoi.os "linux" -}}
{{ if eq .chezmoi.osRelease.id "fedora" -}}

# Enable RPM Fusion repositories for additional packages
if ! dnf repolist | grep -q rpmfusion; then
    echo "Enabling RPM Fusion repositories..."
    sudo dnf install -y \
        https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm \
        https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm
fi

# Enable Flathub
if ! flatpak remotes | grep -q flathub; then
    echo "Adding Flathub repository..."
    flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
fi

# Enable COPR for additional packages
echo "Enabling useful COPR repositories..."
sudo dnf copr enable -y atim/lazygit 2>/dev/null || true
sudo dnf copr enable -y atim/lazydocker 2>/dev/null || true
sudo dnf copr enable -y maveonair/jetbrains-mono-nerd-fonts 2>/dev/null || true

# Update system
echo "Updating system packages..."
sudo dnf update -y

# Install DNF packages
echo "Installing DNF packages..."
{{ range .packages.linux.dnf -}}
sudo dnf install -y {{ . | quote }} || echo "Failed to install {{ . }}, continuing..."
{{ end -}}

# Install Flatpak applications
echo "Installing Flatpak applications..."
{{ range .packages.linux.flatpak -}}
flatpak install -y flathub {{ . | quote }} || echo "Failed to install {{ . }}, continuing..."
{{ end -}}

# Install mise (replacement for asdf)
if ! command -v mise &> /dev/null; then
    echo "Installing mise..."
    curl https://mise.run | sh

    # Add mise to PATH for this session
    export PATH="$HOME/.local/bin:$PATH"
fi

# Install mise toolchains (Node, Python, Go, Rust, Terraform, etc.)
if command -v mise &> /dev/null; then
    echo "Installing development toolchains via mise..."
    echo "This may take a while as it compiles Rust and other tools..."
    mise install
else
    echo "Warning: mise not found in PATH. You may need to restart your shell and run 'mise install' manually."
fi

# Enable and start Podman socket (makes Docker API available)
echo "Enabling Podman socket..."
systemctl --user enable --now podman.socket

# Enable and start Tailscale
echo "Enabling Tailscale..."
sudo systemctl enable --now tailscaled

# Enable and start libvirtd for KVM/QEMU virtualization
if command -v virt-manager &> /dev/null; then
    echo "Enabling libvirtd for virtualization..."
    sudo systemctl enable --now libvirtd
    # Add user to libvirt group
    sudo usermod -a -G libvirt "$USER"
fi

echo "Package installation complete!"
echo ""
echo "Important: You may need to log out and back in for group changes to take effect."

{{ else if or (eq .chezmoi.osRelease.id "ubuntu") (eq .chezmoi.osRelease.id "debian") -}}

# Headless Ubuntu/Debian. SYSTEM packages need root; the full CLI toolset
# comes from mise (no privilege). We auto-detect how — if at all — we can run
# privileged commands and SKIP system packages cleanly when we can't, so the
# run still completes and mise still gives you a working environment.
export DEBIAN_FRONTEND=noninteractive

SUDO=""
if [ "$(id -u)" -eq 0 ]; then
    SUDO=""                                   # already root
elif sudo -n true 2>/dev/null; then
    SUDO="sudo"                               # passwordless sudo
elif [ -t 0 ] && sudo -v 2>/dev/null; then
    SUDO="sudo"                               # interactive: prompt + cache
fi

if [ "$(id -u)" -eq 0 ] || [ -n "$SUDO" ]; then
    echo "Installing apt prerequisites..."
    $SUDO apt-get update -y
    $SUDO apt-get install -y ca-certificates curl wget gnupg

    # System packages (best-effort; a package missing on a given release is
    # skipped without aborting the run).
    echo "Installing apt packages..."
{{ range .packages.linux.apt -}}
    $SUDO apt-get install -y {{ . | quote }} || echo "Failed to install {{ . }}, continuing..."
{{ end -}}
else
    echo "No sudo available (non-admin user) — skipping system packages."
    echo "The CLI tools below still install via mise. If you gain admin later,"
    echo "re-run 'chezmoi apply' to add the system packages."
fi

# Install mise if not already present (installs into ~/.local — no privilege)
if ! command -v mise &> /dev/null && [ ! -x "$HOME/.local/bin/mise" ]; then
    echo "Installing mise..."
    curl https://mise.run | sh
fi
export PATH="$HOME/.local/bin:$PATH"

# Install toolchains AND CLI tools via mise (Node, Python, Go, Rust, ripgrep,
# fd, bat, fzf, jq, gh, neovim, lazygit, delta, …) — all per-user, no sudo.
if command -v mise &> /dev/null; then
    echo "Installing toolchains and CLI tools via mise..."
    echo "This may take a while on first run as it downloads everything..."
    mise install
else
    echo "Warning: mise not found in PATH. You may need to restart your shell and run 'mise install' manually."
fi

# Enable the Podman socket (Docker-compatible API) if Podman was installed
if command -v podman &> /dev/null; then
    echo "Enabling Podman socket..."
    systemctl --user enable --now podman.socket 2>/dev/null || true
fi

echo "Package installation complete!"

{{ else -}}
echo "Skipping: unsupported Linux distribution ({{ .chezmoi.osRelease.id }})"
{{ end -}}
{{ else -}}
echo "Skipping: not on Linux"
{{ end -}}
