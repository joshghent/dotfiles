#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}
set -e

# Install Homebrew if it isn't already installed
if ! command -v brew &>/dev/null; then
  # brew may be installed but not on PATH (fresh non-interactive shell)
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  else
    echo "Homebrew not found, installing..."
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    if [ -x /opt/homebrew/bin/brew ]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    else
      eval "$(/usr/local/bin/brew shellenv)"
    fi
  fi
fi

# Don't abort the whole chezmoi run if a single package fails to install
# (transient download errors, renamed formulae, etc.). brew bundle exits
# non-zero if anything failed; we report it but keep going so the rest of
# the setup (services, mise, macOS defaults) still runs.
set +e
brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ if (index . "casks_enabled") -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ end -}}
EOF
bundle_status=$?
if [ $bundle_status -ne 0 ]; then
  echo ""
  echo "WARN: brew bundle reported failures (exit $bundle_status)."
  echo "      The rest of setup will continue. Re-run 'chezmoi apply' or"
  echo "      'brew bundle' later to retry any packages that failed."
fi
{{ else -}}
echo "Skipping: not on Darwin (macOS)"
{{ end -}}
